---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seoDefaultOgImage, seoPages } from '../data/seo-config';
import { youtubeVideos } from '../data/youtube-videos';
import { normalizeYoutubeId } from '../lib/youtube-id';

const videos = youtubeVideos
	.map((v) => ({
		...v,
		youtubeId: normalizeYoutubeId(v.youtubeId ?? ''),
	}))
	.filter((v) => v.youtubeId.length > 0);
const firstId = videos[0]?.youtubeId;
const ogImage = firstId
	? `https://img.youtube.com/vi/${firstId}/maxresdefault.jpg`
	: (seoPages.video.ogImage ?? seoDefaultOgImage);

/** Parametrul `origin` aliniază player-ul cu referrer-ul și evită eroarea 153 la embed. */
function youtubeEmbedSrc(videoId: string): string {
	const q = new URLSearchParams({
		rel: '0',
		enablejsapi: '1',
		origin: Astro.url.origin,
	});
	return `https://www.youtube-nocookie.com/embed/${videoId}?${q.toString()}`;
}
---

<BaseLayout title={seoPages.video.title} description={seoPages.video.description} ogImage={ogImage}>
	<div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
		<div class="mx-auto max-w-3xl text-center">
			<h1 class="text-4xl font-medium sm:text-5xl">Video</h1>
			<p class="mx-auto mt-2 h-px w-16 bg-accent" aria-hidden="true"></p>
			<p class="mx-auto mt-6 max-w-xl text-ink-muted">
				Fragmente de la evenimente — materiale publicate pe YouTube. Pentru oferte sau întrebări,{' '}
				<a href="/contact/" class="text-ink underline decoration-ink/25 underline-offset-4 hover:text-accent">
					scrie-ne
				</a>
				.
			</p>
		</div>

		{
			videos.length === 0 ? (
				<div class="mx-auto mt-16 max-w-xl rounded-sm border border-ink/10 bg-white/40 px-6 py-10 text-center text-ink-muted">
					<p>
						Aici vor apărea videoclipurile după ce adaugi ID-uri în{' '}
						<code class="text-xs text-ink">src/data/youtube-videos.ts</code>.
					</p>
				</div>
			) : (
				<ul class="mx-auto mt-16 grid max-w-4xl list-none gap-14 sm:gap-16">
					{videos.map((v) => {
						const id = v.youtubeId.trim();
						const src = youtubeEmbedSrc(id);
						const embedTitle = v.title
							? `Video YouTube — ${v.title}`
							: `Video YouTube Firobros — ${id}`;
						return (
							<li>
								<div class="overflow-hidden rounded-sm bg-ink/5 shadow-sm ring-1 ring-ink/5">
									<div class="relative aspect-video w-full">
										<iframe
											src={src}
											class="absolute inset-0 h-full w-full"
											title={embedTitle}
											allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
											allowfullscreen
											referrerpolicy="strict-origin-when-cross-origin"
											loading="lazy"
										/>
									</div>
								</div>
								{v.title ? (
									<h2 class="mt-4 text-center font-serif text-xl text-ink sm:text-left">{v.title}</h2>
								) : null}
								{v.caption ? (
									<p class="mt-2 text-center text-sm text-ink-muted sm:text-left">{v.caption}</p>
								) : null}
								<p class="mt-3 text-center sm:text-left">
									<a
										href={`https://www.youtube.com/watch?v=${id}`}
										class="text-sm text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent"
										target="_blank"
										rel="noopener noreferrer"
									>
										Deschide pe YouTube
									</a>
								</p>
							</li>
						);
					})}
				</ul>
			)
		}
	</div>
</BaseLayout>
