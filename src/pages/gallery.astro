---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryMasonry from '../components/gallery/GalleryMasonry.astro';
---

<BaseLayout
	title="Gallery — Aurelia & Lens"
	description="A curated selection of wedding stories — ceremonies, portraits, and quiet details."
>
	<div class="mx-auto max-w-6xl px-5 pt-16 pb-4 text-center sm:px-8 sm:pt-24">
		<h1 class="text-4xl font-medium sm:text-5xl">Gallery</h1>
		<p class="mx-auto mt-2 h-px w-16 bg-accent" aria-hidden="true"></p>
		<p class="mx-auto mt-6 max-w-lg text-ink-muted">
			Images load as you scroll — optimized as AVIF and WebP at build time for fast mobile browsing.
		</p>
	</div>
	<GalleryMasonry />
</BaseLayout>
