---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryMasonry from '../components/gallery/GalleryMasonry.astro';
import { getPortfolioPhotos, type GalleryCategory } from '../lib/portfolio';

const allowed: GalleryCategory[] = ['cununie', 'nunta', 'trash-the-dress'];
const param = Astro.url.searchParams.get('categorie');
const filter = param && allowed.includes(param as GalleryCategory) ? (param as GalleryCategory) : null;
const photos = getPortfolioPhotos(filter);

const chips: { slug: string | null; label: string }[] = [
	{ slug: null, label: 'Toate' },
	{ slug: 'cununie', label: 'Cununie' },
	{ slug: 'nunta', label: 'Nuntă' },
	{ slug: 'trash-the-dress', label: 'Trash the dress' },
];
---

<BaseLayout
	title="Portofoliu — Firobros"
	description="Fotografie și film de nuntă: ceremonie, petrecere și sesiuni după ziua evenimentului."
	ogImage="https://images.unsplash.com/photo-1522673607200-164d1b6ce486?auto=format&w=1200&q=85"
>
	<div class="mx-auto max-w-6xl px-5 pt-16 pb-6 text-center sm:px-8 sm:pt-24">
		<h1 class="text-4xl font-medium sm:text-5xl">Portofoliu</h1>
		<p class="mx-auto mt-2 h-px w-16 bg-accent" aria-hidden="true"></p>
		<p class="mx-auto mt-6 max-w-lg text-ink-muted">
			Masonry cu proporții naturale — apasă pe o fotografie pentru a o vedea mare. Galeria include
			ceremonie, petrecere și sesiuni „trash the dress”.
		</p>

		<nav aria-label="Categorii portofoliu" class="mt-10 flex flex-wrap justify-center gap-2 sm:gap-3">
			{
				chips.map(({ slug, label }) => {
					const href = slug ? `/portofoliu?categorie=${slug}` : '/portofoliu';
					const active = filter === slug || (slug === null && filter === null);
					return (
						<a
							href={href}
							class:list={[
								'border px-4 py-2 text-xs font-medium uppercase tracking-widest transition',
								active
									? 'border-ink bg-ink text-cream'
									: 'border-ink/15 bg-white/60 text-ink-muted hover:border-ink/30 hover:text-ink',
							]}
						>
							{label}
						</a>
					);
				})
			}
		</nav>
	</div>

	{photos.length === 0 ? (
		<div class="mx-auto max-w-xl px-5 pb-20 text-center text-ink-muted">
			<p>
				{filter
					? 'Nu există imagini în această categorie. Alege „Toate” sau adaugă fișiere în subfolderul potrivit.'
					: 'Portofoliul folosește doar imagini din proiect: pune fotografiile în '}
				{!filter && (
					<>
						<code class="text-xs text-ink">src/assets/images/portfolio/cununie/</code>,{' '}
						<code class="text-xs text-ink">nunta/</code> sau{' '}
						<code class="text-xs text-ink">trash-the-dress/</code>
						{' — apoi revino aici; categoriile de sus le filtrează automat.'}
					</>
				)}
			</p>
		</div>
	) : (
		<GalleryMasonry photos={photos} />
	)}
</BaseLayout>
