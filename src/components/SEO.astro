---
/**
 * Meta SEO reutilizabil: canonical, Open Graph, Twitter Card, cuvinte cheie.
 * Folosit în `BaseLayout.astro` (<head>).
 */
import { seoDefaultOgImage, seoPrimaryKeywords, seoSiteName } from '../data/seo-config';

type Props = {
	title: string;
	description: string;
	/** URL absolut sau path relativ la `site` pentru OG / Twitter */
	image?: string;
	noindex?: boolean;
	/** Cuvinte cheie; implicit lista de brand din seo-config */
	keywords?: string[];
};

const {
	title,
	description,
	image,
	noindex = false,
	keywords = [...seoPrimaryKeywords],
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const rawOg = image ?? seoDefaultOgImage;
const ogImageAbsolute = /^https?:\/\//i.test(rawOg) ? rawOg : new URL(rawOg, siteUrl).href;

const keywordContent = keywords.filter(Boolean).join(', ');
---

<title>{title}</title>
<meta name="description" content={description} />
{keywordContent && <meta name="keywords" content={keywordContent} />}
{noindex && <meta name="robots" content="noindex, follow" />}
<link rel="canonical" href={canonicalURL.href} />

<meta property="og:site_name" content={seoSiteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="ro_RO" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
