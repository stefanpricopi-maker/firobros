---
---

<section class="mx-auto max-w-xl">
	<h2 class="font-serif text-2xl font-medium text-ink">Trimite un mesaj</h2>
	<p class="mt-2 text-sm text-ink-muted">
		Spune-ne data evenimentului, locația și ce vă doriți la foto și film. Răspundem de obicei în 1–2 zile
		lucrătoare.
	</p>

	<form
		name="contact"
		method="POST"
		data-netlify="true"
		netlify-honeypot="bot-field"
		action="/contact/success/"
		class="mt-10 space-y-6"
	>
		<input type="hidden" name="form-name" value="contact" />
		<p class="hidden">
			<label>
				Nu completa acest câmp: <input name="bot-field" tabindex="-1" autocomplete="off" />
			</label>
		</p>

		<div>
			<label for="name" class="block text-xs font-medium uppercase tracking-widest text-ink-muted">
				Nume
			</label>
			<input
				type="text"
				id="name"
				name="name"
				required
				autocomplete="name"
				placeholder="Prenume sau nume complet"
				class="mt-2 w-full border border-ink/15 bg-white px-4 py-3 text-ink outline-none transition placeholder:text-ink-muted/50 focus:border-accent"
			/>
		</div>

		<div>
			<label for="email" class="block text-xs font-medium uppercase tracking-widest text-ink-muted">
				Adresă de e-mail
			</label>
			<input
				type="email"
				id="email"
				name="email"
				required
				autocomplete="email"
				placeholder="prenume@exemplu.ro"
				class="mt-2 w-full border border-ink/15 bg-white px-4 py-3 text-ink outline-none transition placeholder:text-ink-muted/50 focus:border-accent"
			/>
		</div>

		<div>
			<label for="phone" class="block text-xs font-medium uppercase tracking-widest text-ink-muted">
				Telefon <span class="font-normal normal-case text-ink-muted/80">(opțional)</span>
			</label>
			<input
				type="tel"
				id="phone"
				name="phone"
				autocomplete="tel"
				placeholder="+40 …"
				class="mt-2 w-full border border-ink/15 bg-white px-4 py-3 text-ink outline-none transition placeholder:text-ink-muted/50 focus:border-accent"
			/>
		</div>

		<div>
			<label for="wedding-date" class="block text-xs font-medium uppercase tracking-widest text-ink-muted">
				Data evenimentului <span class="font-normal normal-case text-ink-muted/80">(opțional)</span>
			</label>
			<input
				type="text"
				id="wedding-date"
				name="wedding-date"
				placeholder="ex.: 12 iulie 2026 sau luna / anul"
				class="mt-2 w-full border border-ink/15 bg-white px-4 py-3 text-ink outline-none transition placeholder:text-ink-muted/50 focus:border-accent"
			/>
		</div>

		<div>
			<label for="message" class="block text-xs font-medium uppercase tracking-widest text-ink-muted">
				Mesaj
			</label>
			<textarea
				id="message"
				name="message"
				required
				rows={6}
				placeholder="Locație, număr de invitați, ce vă doriți la album / film…"
				class="mt-2 w-full resize-y border border-ink/15 bg-white px-4 py-3 text-ink outline-none transition placeholder:text-ink-muted/50 focus:border-accent"
			></textarea>
		</div>

		<button
			type="submit"
			class="w-full border border-ink bg-ink px-6 py-3.5 text-xs font-medium uppercase tracking-widest text-cream transition hover:bg-ink/90 sm:w-auto"
		>
			Trimite mesajul
		</button>
	</form>
</section>
