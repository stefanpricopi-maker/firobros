---
/** Replace hrefs with your real profiles before launch. */
const socials = [
	{ label: 'Instagram', href: 'https://www.instagram.com/' },
	{ label: 'Pinterest', href: 'https://www.pinterest.com/' },
	{ label: 'Email', href: 'mailto:hello@example.com' },
];
---

<section class="border-t border-ink/10 pt-12">
	<h2 class="font-serif text-xl font-medium text-ink">Elsewhere</h2>
	<ul class="mt-6 flex flex-wrap gap-x-8 gap-y-3">
		{
			socials.map((s) => (
				<li>
					<a
						href={s.href}
						class="text-sm text-ink-muted underline-offset-4 transition hover:text-ink hover:underline"
						target="_blank"
						rel="noopener noreferrer"
					>
						{s.label}
					</a>
				</li>
			))
		}
	</ul>
</section>
