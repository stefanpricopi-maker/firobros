---
import { filmSection } from '../../data/film';

const { title, lead, body, youtubeVideoId, vimeoVideoId, embedTitle } = filmSection;

const yt = youtubeVideoId.trim();
const vm = vimeoVideoId.trim();
const hasYoutube = yt.length > 0;
const hasVimeo = vm.length > 0 && !hasYoutube;
const showEmbed = hasYoutube || hasVimeo;

const embedSrc = hasYoutube
	? `https://www.youtube-nocookie.com/embed/${yt}?rel=0`
	: hasVimeo
		? `https://player.vimeo.com/video/${vm}`
		: '';
---

<section
	id="film"
	class="scroll-mt-24 border-t border-ink/10 bg-white/50 px-5 py-20 sm:px-8 sm:py-28"
	aria-labelledby="film-heading"
>
	<div class="mx-auto max-w-3xl text-center">
		<h2 id="film-heading" class="text-3xl font-medium sm:text-4xl">{title}</h2>
		<p class="mx-auto mt-2 h-px w-16 bg-accent" aria-hidden="true"></p>
		<p class="mt-8 text-lg leading-relaxed text-ink-muted">{lead}</p>
		<p class="mt-4 leading-relaxed text-ink-muted">{body}</p>
	</div>

	{
		showEmbed && (
			<div class="mx-auto mt-14 max-w-4xl overflow-hidden rounded-sm bg-ink/5 shadow-sm ring-1 ring-ink/5">
				<div class="relative aspect-video w-full">
					<iframe
						src={embedSrc}
						class="absolute inset-0 h-full w-full"
						title={embedTitle}
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
						allowfullscreen
						referrerpolicy="strict-origin-when-cross-origin"
						loading="lazy"
					/>
				</div>
			</div>
		)
	}

	<div class="mx-auto mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
		<a
			href="/contact/"
			class="inline-flex border border-ink bg-ink px-8 py-3 text-xs font-medium uppercase tracking-widest text-cream transition hover:bg-ink/90"
		>
			Cere o previzualizare sau ofertă pentru film
		</a>
		<a
			href="/portofoliu/"
			class="inline-flex border border-ink/20 bg-transparent px-8 py-3 text-xs font-medium uppercase tracking-widest text-ink transition hover:border-ink/40"
		>
			Vezi și fotografiile
		</a>
	</div>
</section>
