---
import type { ImageMetadata } from 'astro';
import OptimizedPicture from '../OptimizedPicture.astro';

// Orice imagine din `src/assets/images/hero/` e folosită ca hero pe pagina principală. Dacă e gol, rămâne Unsplash.
const heroModules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/images/hero/*.{jpeg,jpg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
	{ eager: true },
);

const sortedPaths = Object.keys(heroModules).sort();
const firstPath = sortedPaths[0];
const heroAsset = firstPath ? heroModules[firstPath]?.default : null;

const heroFallback =
	'https://images.unsplash.com/photo-1522673607200-164d1b6ce486?auto=format&fit=crop&w=2400&q=85';

const src = heroAsset ?? heroFallback;
const width = heroAsset?.width ?? 2400;
const height = heroAsset?.height ?? 1600;
const alt = heroAsset
	? 'Firobros — imagine principală'
	: 'Moment de nuntă în lumină naturală pe coastă';
---

<section
	class="relative isolate min-h-[70vh] w-full overflow-hidden sm:min-h-[85vh]"
	aria-label="Imagine principală"
>
	<h1 class="sr-only">Firobros — image and film</h1>
	<div class="hero-media absolute inset-0 z-0" aria-hidden="true">
		<OptimizedPicture
			src={src}
			alt={alt}
			width={width}
			height={height}
			widths={[640, 960, 1280, 1920, 2400]}
			sizes="100vw"
			loading="eager"
			fetchpriority="high"
		/>
	</div>
</section>

<style>
	.hero-media :global(picture) {
		display: block;
		height: 100%;
		width: 100%;
	}
	.hero-media :global(picture img),
	.hero-media :global(> img) {
		display: block;
		height: 100%;
		width: 100%;
		object-fit: cover;
		object-position: center;
	}
</style>
