---
import type { ImageMetadata } from 'astro';
import OptimizedPicture from '../OptimizedPicture.astro';

const MAX_SLIDES = 10;

/**
 * Imagini din `src/assets/images/hero/` (și subfoldere).
 * După ce adaugi/ștergi fișiere, repornește `npm run dev` — Vite poate să nu reîmprospăteze glob-ul la cald.
 */
const heroModules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/images/hero/**/*.{jpeg,jpg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
	{ eager: true },
);

const sortedPaths = Object.keys(heroModules).sort().slice(0, MAX_SLIDES);

type HeroSlide = {
	path: string;
	image: ImageMetadata;
	pathHint: string;
};

const slides: HeroSlide[] = [];
for (const path of sortedPaths) {
	const mod = heroModules[path]?.default;
	if (!mod) continue;
	slides.push({
		path,
		image: mod,
		pathHint: path.replace(/^\.\.\/\.\.\//, ''),
	});
}

const heroFallback =
	'https://images.unsplash.com/photo-1522673607200-164d1b6ce486?auto=format&fit=crop&w=2400&q=85';

const useSlider = slides.length > 1;
const singleLocal = slides.length === 1 ? slides[0] : null;

const fallbackAlt =
	'Moment de nuntă în lumină naturală — Firobros Image & Film';
const sharedAlt =
	'Firobros Image & Film — fotograf și video nunți neoprotestante Cluj';

/** Pauză între diapozitive (autoplay). */
const HERO_AUTOPLAY_MS = 7000;
/** Durata crossfade între imagini. */
const HERO_FADE_MS = 900;
/** Minim px pe orizontală pentru a schimba slide-ul la swipe. */
const HERO_SWIPE_THRESHOLD_PX = 48;
---

<section
	class="relative isolate min-h-[70vh] w-full overflow-hidden sm:min-h-[85vh]"
	aria-label={useSlider ? 'Carusel imagini principale' : 'Imagine principală'}
>
	<h1 class="sr-only">Firobros Image & Film — foto și video nunți neoprotestante, Cluj-Napoca</h1>

	{
		slides.length === 0 ? (
			<div class="hero-media absolute inset-0 z-0" aria-hidden="true">
				<OptimizedPicture
					src={heroFallback}
					alt={fallbackAlt}
					width={2400}
					height={1600}
					widths={[640, 960, 1280, 1920, 2400]}
					sizes="100vw"
					loading="eager"
					fetchpriority="high"
				/>
			</div>
		) : !useSlider && singleLocal ? (
			<div class="hero-media absolute inset-0 z-0" aria-hidden="true">
				<OptimizedPicture
					src={singleLocal.image}
					alt={sharedAlt}
					filePathHint={singleLocal.pathHint}
					width={singleLocal.image.width}
					height={singleLocal.image.height}
					widths={[640, 960, 1280, 1920, 2400]}
					sizes="100vw"
					loading="eager"
					fetchpriority="high"
				/>
			</div>
		) : (
			<div
				class="absolute inset-0 z-0"
				data-hero-slider
				data-interval-ms={HERO_AUTOPLAY_MS}
				data-swipe-threshold={HERO_SWIPE_THRESHOLD_PX}
				style={{ '--hero-fade-ms': `${HERO_FADE_MS}ms` }}
			>
				<div class="hero-media hero-slides relative h-full min-h-[70vh] w-full touch-pan-y sm:min-h-[85vh]">
					{slides.map((slide, i) => (
						<div
							class:list={['hero-slide', i === 0 && 'is-active']}
							data-hero-slide
							aria-hidden={i === 0 ? 'false' : 'true'}
						>
							<OptimizedPicture
								src={slide.image}
								alt={sharedAlt}
								filePathHint={slide.pathHint}
								width={slide.image.width}
								height={slide.image.height}
								widths={[640, 960, 1280, 1920, 2400]}
								sizes="100vw"
								loading={i === 0 ? 'eager' : 'lazy'}
								fetchpriority={i === 0 ? 'high' : undefined}
							/>
						</div>
					))}
				</div>

				<div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 flex items-end justify-center gap-3 pb-6 sm:pb-8">
					<div
						class="pointer-events-auto flex items-center gap-2 rounded-sm bg-ink/35 px-2 py-2 backdrop-blur-sm"
						data-hero-controls
					>
						<button
							type="button"
							class="hero-slider-btn rounded-sm px-2 py-1.5 text-cream/90 transition hover:bg-white/15 hover:text-cream"
							data-hero-prev
							aria-label="Imaginea anterioară din carusel"
						>
							<span class="sr-only">Anterior</span>
							<span aria-hidden="true" class="text-lg leading-none">
								‹
							</span>
						</button>
						<div class="flex items-center gap-1.5 px-1" data-hero-dots>
							{slides.map((_, i) => (
								<button
									type="button"
									class:list={['hero-dot', i === 0 && 'is-active']}
									data-hero-dot={i}
									aria-label={`Imaginea ${i + 1} din ${slides.length}`}
									aria-current={i === 0 ? 'true' : undefined}
								/>
							))}
						</div>
						<button
							type="button"
							class="hero-slider-btn rounded-sm px-2 py-1.5 text-cream/90 transition hover:bg-white/15 hover:text-cream"
							data-hero-next
							aria-label="Imaginea următoare din carusel"
						>
							<span class="sr-only">Următor</span>
							<span aria-hidden="true" class="text-lg leading-none">
								›
							</span>
						</button>
					</div>
				</div>
			</div>
		)
	}
</section>

{useSlider && (
	<script is:inline>
		function initHeroSlider() {
			var root = document.querySelector('[data-hero-slider]');
			if (!root) return;
			var controls = root.querySelector('[data-hero-controls]');
			var track = root.querySelector('.hero-slides');
			var slides = root.querySelectorAll('[data-hero-slide]');
			var dots = root.querySelectorAll('[data-hero-dot]');
			var prev = root.querySelector('[data-hero-prev]');
			var next = root.querySelector('[data-hero-next]');
			if (!slides.length) return;

			var i = 0;
			var n = slides.length;
			var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			var intervalMs = parseInt(root.getAttribute('data-interval-ms') || '7000', 10) || 7000;
			var swipeThreshold = parseInt(root.getAttribute('data-swipe-threshold') || '48', 10) || 48;
			var timer = null;
			var touchStartX = 0;
			var touchStartY = 0;

			function go(idx) {
				i = ((idx % n) + n) % n;
				slides.forEach(function (el, j) {
					var on = j === i;
					el.classList.toggle('is-active', on);
					el.setAttribute('aria-hidden', on ? 'false' : 'true');
				});
				dots.forEach(function (dot, j) {
					var on = j === i;
					dot.classList.toggle('is-active', on);
					if (on) dot.setAttribute('aria-current', 'true');
					else dot.removeAttribute('aria-current');
				});
			}

			function start() {
				if (reduced || n < 2) return;
				stop();
				timer = window.setInterval(function () {
					go(i + 1);
				}, intervalMs);
			}

			function stop() {
				if (timer) {
					window.clearInterval(timer);
					timer = null;
				}
			}

			if (prev)
				prev.addEventListener('click', function () {
					go(i - 1);
					start();
				});
			if (next)
				next.addEventListener('click', function () {
					go(i + 1);
					start();
				});
			dots.forEach(function (dot, j) {
				dot.addEventListener('click', function () {
					go(j);
					start();
				});
			});

			/** Pauză doar deasupra butoanelor, nu pe întreaga zonă hero (altfel autoplay-ul rămânea oprit). */
			if (controls) {
				controls.addEventListener('mouseenter', stop);
				controls.addEventListener('mouseleave', start);
			}
			root.addEventListener('focusin', stop);
			root.addEventListener('focusout', function (e) {
				var rt = e.relatedTarget;
				if (!rt || !root.contains(rt)) start();
			});

			if (track && n > 1) {
				track.addEventListener(
					'touchstart',
					function (e) {
						if (e.touches.length !== 1) return;
						touchStartX = e.touches[0].clientX;
						touchStartY = e.touches[0].clientY;
					},
					{ passive: true },
				);
				track.addEventListener(
					'touchend',
					function (e) {
						if (!e.changedTouches.length) return;
						var dx = e.changedTouches[0].clientX - touchStartX;
						var dy = e.changedTouches[0].clientY - touchStartY;
						if (Math.abs(dx) < swipeThreshold) return;
						if (Math.abs(dx) <= Math.abs(dy)) return;
						if (dx < 0) go(i + 1);
						else go(i - 1);
						start();
					},
					{ passive: true },
				);
			}

			start();
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initHeroSlider);
		} else {
			initHeroSlider();
		}
	</script>
)}

<style>
	.hero-media :global(picture) {
		display: block;
		height: 100%;
		width: 100%;
	}
	.hero-media :global(picture img),
	.hero-media :global(> img) {
		display: block;
		height: 100%;
		width: 100%;
		object-fit: cover;
		object-position: center;
	}

	.hero-slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity var(--hero-fade-ms, 900ms) ease-in-out;
		pointer-events: none;
	}
	.hero-slide.is-active {
		opacity: 1;
		z-index: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-slide {
			transition: none;
		}
	}

	.hero-dot {
		height: 0.5rem;
		width: 0.5rem;
		border-radius: 9999px;
		border: none;
		padding: 0;
		cursor: pointer;
		background: color-mix(in srgb, var(--color-cream) 40%, transparent);
		transition: background 0.2s ease, transform 0.2s ease;
	}
	.hero-dot:hover {
		background: color-mix(in srgb, var(--color-cream) 70%, transparent);
	}
	.hero-dot.is-active {
		background: var(--color-cream);
		transform: scale(1.1);
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-dot {
			transition: none;
		}
	}
</style>
