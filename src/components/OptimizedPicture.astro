---
/**
 * Wraps `Picture` with AVIF + WebP sources. Remote URLs must be allowlisted in `astro.config.mjs`.
 *
 * În `astro dev`, imaginile remote ocolesc `/_image` (Sharp/fetch pot da 500 în unele medii) și folosesc
 * direct URL-ul — la `astro build` rămâne optimizarea completă.
 */
import { Picture } from 'astro:assets';

type Props = {
	src: import('astro').ImageMetadata | string;
	alt: string;
	width: number;
	height: number;
	widths?: number[];
	sizes?: string;
	class?: string;
	loading?: 'lazy' | 'eager';
	fetchpriority?: 'high' | 'low' | 'auto';
	formats?: ('avif' | 'webp' | 'jpeg' | 'png')[];
};

const {
	src,
	alt,
	width,
	height,
	widths = [400, 640, 960, 1280, 1600],
	sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px',
	class: className,
	loading = 'lazy',
	fetchpriority,
	formats = ['avif', 'webp'],
} = Astro.props;

const isDevRemote =
	import.meta.env.DEV &&
	typeof src === 'string' &&
	(src.startsWith('https://') || src.startsWith('http://'));

function remoteSrcAtWidth(url: string, w: number): string {
	try {
		const u = new URL(url);
		u.searchParams.set('w', String(w));
		return u.href;
	} catch {
		return url;
	}
}
---

{
	isDevRemote ? (
		<img
			src={remoteSrcAtWidth(src as string, width)}
			srcset={(widths as number[])
				.map((w) => `${remoteSrcAtWidth(src as string, w)} ${w}w`)
				.join(', ')}
			sizes={sizes}
			alt={alt}
			width={width}
			height={height}
			class={className}
			loading={loading}
			fetchpriority={fetchpriority}
			decoding="async"
		/>
	) : (
		<Picture
			src={src}
			alt={alt}
			width={width}
			height={height}
			widths={widths}
			sizes={sizes}
			formats={formats}
			fallbackFormat="jpeg"
			class={className}
			loading={loading}
			fetchpriority={fetchpriority}
		/>
	)
}
