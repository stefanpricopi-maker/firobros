---
/**
 * Imagini prin astro:assets — **WebP primul** în lista de formate (viteză), apoi AVIF.
 * Dacă `alt` lipsește, se derivează din `filePathHint` sau din `src` (nume fișier).
 */
import { Picture } from 'astro:assets';
import { resolveImageAlt } from '../lib/image-alt';

type Props = {
	src: import('astro').ImageMetadata | string;
	alt?: string;
	/** Cale modul/glob (ex. din `import.meta.glob`) pentru alt când `alt` lipsește */
	filePathHint?: string;
	width: number;
	height: number;
	widths?: number[];
	sizes?: string;
	class?: string;
	loading?: 'lazy' | 'eager';
	fetchpriority?: 'high' | 'low' | 'auto';
	/** Ordinea: WebP primul (brief viteză), apoi AVIF pentru browsere moderne */
	formats?: ('avif' | 'webp' | 'jpeg' | 'png')[];
};

const {
	src,
	alt,
	filePathHint,
	width,
	height,
	widths = [400, 640, 960, 1280, 1600],
	sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px',
	class: className,
	loading = 'lazy',
	fetchpriority,
	formats = ['webp', 'avif'],
} = Astro.props;

const resolvedAlt = resolveImageAlt(alt, { src, filePathHint });

const isDevRemote =
	import.meta.env.DEV &&
	typeof src === 'string' &&
	(src.startsWith('https://') || src.startsWith('http://'));

function remoteSrcAtWidth(url: string, w: number): string {
	try {
		const u = new URL(url);
		u.searchParams.set('w', String(w));
		return u.href;
	} catch {
		return url;
	}
}
---

{
	isDevRemote ? (
		<img
			src={remoteSrcAtWidth(src as string, width)}
			srcset={(widths as number[])
				.map((w) => `${remoteSrcAtWidth(src as string, w)} ${w}w`)
				.join(', ')}
			sizes={sizes}
			alt={resolvedAlt}
			width={width}
			height={height}
			class={className}
			loading={loading}
			fetchpriority={fetchpriority}
			decoding="async"
		/>
	) : (
		<Picture
			src={src}
			alt={resolvedAlt}
			width={width}
			height={height}
			widths={widths}
			sizes={sizes}
			formats={formats}
			fallbackFormat="jpeg"
			class={className}
			loading={loading}
			fetchpriority={fetchpriority}
		/>
	)
}
