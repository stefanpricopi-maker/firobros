---
import OptimizedPicture from '../OptimizedPicture.astro';
import type { PortfolioEntry } from '../../lib/portfolio';

interface Props {
	photos: PortfolioEntry[];
}

const { photos } = Astro.props;
---

<div id="portfolio-masonry" class="masonry-columns mx-auto max-w-6xl px-5 pb-20 sm:px-8">
	<ul class="masonry-inner">
		{
			photos.map((photo) => (
				<li class="masonry-item mb-4 break-inside-avoid sm:mb-5">
					<a
						href={photo.lightboxUrl}
						data-pswp-width={photo.pswpWidth}
						data-pswp-height={photo.pswpHeight}
						class="block overflow-hidden rounded-sm bg-ink/5 outline-none ring-offset-2 transition hover:opacity-95 focus-visible:ring-2 focus-visible:ring-accent"
					>
						<OptimizedPicture
							src={photo.src}
							alt={photo.alt}
							width={photo.width}
							height={photo.height}
							widths={[400, 600, 800, 1000, 1200]}
							sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
							class="w-full rounded-sm bg-ink/5"
							loading="lazy"
						/>
					</a>
				</li>
			))
		}
	</ul>
</div>

<style>
	.masonry-columns {
		column-count: 1;
		column-gap: 1rem;
	}
	@media (min-width: 640px) {
		.masonry-columns {
			column-count: 2;
			column-gap: 1.25rem;
		}
	}
	@media (min-width: 1024px) {
		.masonry-columns {
			column-count: 3;
			column-gap: 1.25rem;
		}
	}
	.masonry-inner {
		display: block;
	}
</style>

<script>
	import PhotoSwipeLightbox from 'photoswipe/lightbox';
	import 'photoswipe/style.css';

	const gallery = document.getElementById('portfolio-masonry');
	if (gallery) {
		const lightbox = new PhotoSwipeLightbox({
			gallery: '#portfolio-masonry',
			children: 'a',
			pswpModule: () => import('photoswipe'),
		});
		lightbox.init();
	}
</script>
