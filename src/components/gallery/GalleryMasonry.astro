---
import OptimizedPicture from '../OptimizedPicture.astro';
import { galleryPhotos } from '../../data/gallery-photos';
---

<div class="masonry-columns mx-auto max-w-6xl px-5 pb-20 sm:px-8">
	<ul class="masonry-inner">
		{
			galleryPhotos.map((photo) => (
				<li class="masonry-item mb-4 break-inside-avoid sm:mb-5">
					<OptimizedPicture
						src={photo.src}
						alt={photo.alt}
						width={photo.width}
						height={photo.height}
						widths={[400, 600, 800, 1000, 1200]}
						sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
						class="w-full rounded-sm bg-ink/5"
						loading="lazy"
					/>
				</li>
			))
		}
	</ul>
</div>

<style>
	.masonry-columns {
		column-count: 1;
		column-gap: 1rem;
	}
	@media (min-width: 640px) {
		.masonry-columns {
			column-count: 2;
			column-gap: 1.25rem;
		}
	}
	@media (min-width: 1024px) {
		.masonry-columns {
			column-count: 3;
			column-gap: 1.25rem;
		}
	}
	.masonry-inner {
		display: block;
	}
</style>
